  <phrase title="option_explain.countryAccessCheckAllowedCountryCodes" version_id="10" version_string="1.0"><![CDATA[These country codes will be allowed to use the Contact us, Log in and Register pages. For this option to work, the Blocked country codes above must be empty. Separate each country code with a comma.<br /><br />Link to country codes: <a href="https://en.wikipedia.org/wiki/ISO_3166-1" target="_blank">https://en.wikipedia.org/wiki/ISO_3166-1</a>]]></phrase>
  <phrase title="option_explain.countryAccessCheckBlockedCountryCodes" version_id="10" version_string="1.0"><![CDATA[These country codes will not be allowed to use the Contact us, Log in and Register pages. For this option to work, the Allowed country codes below must be empty. Separate each country code with a comma.<br /><br />Link to country codes: <a href="https://en.wikipedia.org/wiki/ISO_3166-1" target="_blank">https://en.wikipedia.org/wiki/ISO_3166-1</a>]]></phrase>
  <phrase title="option_explain.countryAccessCheckGeoIp2AutoloadPath" version_id="16" version_string="1.6"><![CDATA[Optional. Enter path to autoload.php file. Example /home/username/public_html/misc/vendor/autoload.php]]></phrase>
  <phrase title="option_explain.countryAccessCheckGeoIp2DatabasePath" version_id="16" version_string="1.6"><![CDATA[Optional. Enter path to GeoLite2-City.mmdb file. Example /home/username/public_html/misc/GeoLite2-City.mmdb]]></phrase>
